PORT=5000
MONGODB_URI=mongodb://localhost:27017/cv_builder
JWT_SECRET=change_this_to_a_long_random_secret
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=YourAdminPassword

# OpenAI — required for Create CV → Generate draft (two API calls: extract job facts, then write CV JSON)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Optional: different model for step 1 (job extraction); defaults to OPENAI_MODEL
# OPENAI_MODEL_EXTRACT=gpt-4o-mini

# Chrome extension ZIP (Workspace → Download Chrome Extension). Hosted APIs often omit monorepo folders:
# - postinstall (server/package.json) copies ../extension-cv-builder → server/extension-cv-builder when the full repo is present
# EXTENSION_COPY_SOURCE=/override/path/extension-cv-builder  # optional: non-default layout for that copy script
# EXTENSION_SOURCE_DIR=/absolute/path/to/extension-cv-builder  # runtime: prefer another folder instead of sibling/inside-server
# EXTENSION_ZIP_PATH=/absolute/path/to/extension-cv-builder.zip
